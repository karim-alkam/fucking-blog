      "updated": 1767781344838,
      "link": null,
      "locked": false,
      "text": "Simple. Gives you a kernel, heap, and\nscheduler. Easy to configure\nstack/heap. Flexible. Does not\nprovide drivers (you write them).",
      "rawText": "Simple. Gives you a kernel, heap, and scheduler. Easy to configure stack/heap. Flexible. Does not provide drivers (you write them).",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Simple. Gives you a kernel, heap, and scheduler. Easy to configure stack/heap. Flexible. Does not provide drivers (you write them).",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "2phckUvz",
      "type": "text",
      "x": 944.2943910441008,
      "y": 2017.5999368696807,
      "width": 276.4212861897433,
