      "isDeleted": false,
      "boundElements": [],
      "updated": 1767781344838,
      "link": null,
      "locked": false,
      "text": "Complex ecosystem. Supported by\nLinux Foundation. Uses Device\nTree for configuration. Provides\ndrivers (e.g., I2C sensor drivers)\nand networking stacks.",
      "rawText": "Complex ecosystem. Supported by Linux Foundation. Uses Device Tree for configuration. Provides drivers (e.g., I2C sensor drivers) and networking stacks.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Complex ecosystem. Supported by Linux Foundation. Uses Device Tree for configuration. Provides drivers (e.g., I2C sensor drivers) and networking stacks.",
      "autoResize": false,
      "lineHeight": 1.25
    },
