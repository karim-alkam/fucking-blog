    },
    {
      "id": "tZjtsDGa",
      "type": "text",
      "x": -1020,
      "y": 340,
      "width": 400,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aN",
      "roundness": null,
      "seed": 1306969727,
      "version": 730,
      "versionNonce": 1901596081,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1767769918903,
      "link": null,
      "locked": false,
      "text": "Key Skill: learn how ur code travels how the CPU\nexecute it also visualizing data flows is essential,\ntools r there but they r not as advance as the\nhigh level OS tools.",
      "rawText": "Key Skill: learn how ur code travels how the CPU execute it also visualizing data flows is essential, tools r there but they r not as advance as the high level OS tools.",
      "fontSize": 16,
