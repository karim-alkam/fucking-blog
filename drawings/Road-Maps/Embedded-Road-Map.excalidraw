      "updated": 1767769918903,
      "link": null,
      "locked": false,
      "text": "Problems here r just impossible to understand u,\nthey happen at a very low level involving multiple\nchips and how they communicate with each other.",
      "rawText": "Problems here r just impossible to understand u, they happen at a very low level involving multiple chips and how they communicate with each other.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problems here r just impossible to understand u, they happen at a very low level involving multiple chips and how they communicate with each other.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "IFl9NHTu",
      "type": "text",
      "x": -1020,
      "y": 280,
      "width": 380,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aM",
      "roundness": null,
      "seed": 70362815,
      "version": 446,
      "versionNonce": 502018001,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1767769918903,
      "link": null,
      "locked": false,
      "text": "You lack the high level OS that makes ur life\neasy.",
