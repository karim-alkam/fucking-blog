    {
      "id": "NMciL3hj",
      "type": "text",
      "x": -500,
      "y": 200,
      "width": 399.2379752462971,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
